{
  "ConnectionStrings": {
    "Database": "Host=postgres;Port=5432;Database=recommendation;Username=postgres;Password=postgres;Include Error Detail=true"
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.Seq"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "ServerUrl": "http://seq:5341" }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "Jwt": {
    "Secret": "super-duper-secret-value-that-should-be-in-user-secrets",
    "Issuer": "recommendation",
    "Audience": "developers",
    "ExpirationInMinutes": 60
  },
  "OpenRouter": {
    "ApiUrl": "https://openrouter.ai",
    "ApiKey": ""
  }
}
